# ---------- Helpers: API Key y cliente OpenAI ----------

def get_api_key():
    """Busca la API key en st.secrets, variables de entorno o .env"""
    # st.secrets (Streamlit Cloud)
    key = None
    source = None
    try:
        if st.secrets.get("OPENAI_API_KEY"):
            key = st.secrets.get("OPENAI_API_KEY")
            source = "st.secrets"
    except Exception:
        pass

    if not key:
        key = os.getenv("OPENAI_API_KEY")
        if key:
            source = ".env / env var"

    return key, source

api_key, key_source = get_api_key()

# Inicializar cliente si SDK está disponible y hay key

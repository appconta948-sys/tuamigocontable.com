# ---------- Asistente IA (lado derecho en una columna) ----------
st.markdown("\n")
col_main, col_ai = st.columns([3,1])

with col_ai:
    st.markdown("### 🤖 Asistente IA")
    if not api_key:
        st.info("Configura OPENAI_API_KEY para activar el asistente.")
    else:
        if "chat" not in st.session_state:
            st.session_state.chat = [{"role": "system", "content": "Eres un asistente contable conciso y profesional."}]

        # Mostrar conversaciones previas
        for msg in st.session_state.chat[1:]:
            role = msg.get("role")
            content = msg.get("content")
            if role == "user":
                st.markdown(f"**Tú:** {content}")
            else:
                st.markdown(f"**IA:** {content}")

        user_input = st.text_input("Escribe tu pregunta...", key="ia_input")
        if user_input:
            st.session_state.chat.append({"role": "user", "content": user_input})
            # Llamada a OpenAI
            try:
                with st.spinner("Generando respuesta..."):
                    response = client.chat.completions.create(
                        model="gpt-4o-mini",
                        messages=st.session_state.chat,
                        max_tokens=500,
                    )

                # Extraer texto de forma segura
                assistant_text = None
                if hasattr(response, "choices") and len(response.choices) > 0:
                    choice = response.choices[0]
                    # Manejar estructura: choice.message.content
                    if hasattr(choice, "message") and isinstance(choice.message, dict):
                        assistant_text = choice.message.get("content")
                    elif hasattr(choice, "message") and hasattr(choice.message, "get"):
                        assistant_text = choice.message.get("content")
                    elif hasattr(choice, "text"):
                        assistant_text = choice.text

                if assistant_text is None:
                    assistant_text = str(response)

                st.session_state.chat.append({"role": "assistant", "content": assistant_text})
                # Limpiar input
                st.session_state.ia_input = ""
                # Rerun para mostrar la respuesta (si es necesario)
                st.experimental_rerun()

            except Exception as e:
                tb = traceback.format_exc()
                st.error("Error llamando a la API de OpenAI. Revisa la key y la conexión.")
                st.code(tb)

